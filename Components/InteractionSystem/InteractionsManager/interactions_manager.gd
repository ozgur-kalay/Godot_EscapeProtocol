extends Node

# Add this script as a global

enum InteractionKeys {
	SELECT_KEY,        ## Generic selection / confirm interaction
	SWITCH_ON,         ## Activates or turns something on
	SWITCH_OFF,        ## Deactivates or turns something off
	DRAG,              ## Allows dragging or moving an object
	CHECK_POINT,       ## Triggers a checkpoint/save point
	POWER_UP,          ## Grants a temporary ability or boost
	DIVERT_LASER,      ## Redirects or alters a laser path
	INVISIBILITY_FIELD,## Enables invisibility or stealth effect
	HIGH_PLATFORM,     ## Interacts with elevated platforms
	SWITCH_TOGGLE,     ## Toggles between on/off states
	DOOR_OPEN,         ## Opens a door or passage
	LIGHTS_ON,         ## Turns Lights on
}
